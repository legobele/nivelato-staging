rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // SSO codes: anyone who knows the code ID can read/delete (unguessable random)
    // Create requires auth. Codes expire via client-side TTL.
    match /sso_codes/{code} {
      allow read, delete: if true;
      allow create: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Users: own read/write, or same-org read (for permission manager)
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId ==
          get(/databases/$(database)/documents/users/$(userId)).data.orgId
      );
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Orgs: owner can write, members can read
    match /orgs/{orgId} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;

      // Deletion requests: any org member can create, owner can read/delete
      match /deletion_requests/{reqId} {
        allow create: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
        allow read, delete: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
      }

      // Jobs: org members can create + read; shared users can read; owner can update/delete
      match /jobs/{jobId} {
        allow create: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId ||
          resource.data.sharedWith.hasAny([request.auth.uid])
        );
        allow update, delete: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
      }
    }
  }
}
