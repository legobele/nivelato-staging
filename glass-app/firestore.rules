rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own user doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Orgs: any authenticated user can CREATE (needed during owner signup)
    // only owner can update/delete their own org
    match /orgs/{orgId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
      allow update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;

      // Jobs: any org member can create/read, owner can delete
      match /jobs/{jobId} {
        allow create: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
        allow read: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
        allow update, delete: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
      }
    }
  }
}
